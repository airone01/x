<script>
  // import anime from "animejs";

  const cellSize = 20 as const;

  const getRows = () => Math.floor((window.innerHeight * 1) / cellSize);
  const getColumns = () => Math.floor(window.innerWidth / cellSize);

  let rows = getRows();
  let columns = getColumns();
  const wrapper: HTMLDivElement = document.querySelector("#grid-wrapper")!;

  enum CellStatus {
    Dead,
    Alive,
  }

  const grid: CellStatus[][] = [[]];

  // Initialize grid with dead cells
  for (var i: number = 0; i < rows; i++) {
    grid[i] = [];
    for (var j: number = 0; j < columns; j++) {
      grid[i]![j] = CellStatus.Dead;
    }
  }

  /**
   * Gets number of alive neighbors
   * @param row Row
   * @param column Column
   */
  const getNeighbors = (row: number, column: number) => {
    let aliveNeighborCount = 0;

    for (var i: number = -1; i < 2; i++) {
      for (var j: number = -1; j < 2; j++) {
        if (i === 0 && j === 0) {
          continue;
        }

        const neighborRow = row + i;
        const neighborColumn = column + j;

        if (
          neighborRow >= 0 &&
          neighborRow < rows &&
          neighborColumn >= 0 &&
          neighborColumn < columns
        ) {
          if (grid[neighborRow]![neighborColumn] === CellStatus.Alive) {
            aliveNeighborCount++;
          }
        }
      }
    }

    return aliveNeighborCount;
  };

  const gameTick = () => {
    let changed: number = 0;

    for (var i: number = 0; i < rows; i++) {
      for (var j: number = 0; j < columns; j++) {
        const cell = grid[i]![j];
        const neighbors = getNeighbors(i, j);

        if (cell === CellStatus.Alive) {
          // Rule 1: Any live cell with fewer than two live neighbours dies, as if by underpopulation.
          if (neighbors < 2) {
            grid[i]![j] = CellStatus.Dead;
            changed++;
          } else if (neighbors === 2 || neighbors === 3) {
            // Rule 2: Any live cell with two or three live neighbours lives on to the next generation.
            grid[i]![j] = CellStatus.Alive;
            changed++;
          } else if (neighbors > 3) {
            // Rule 3: Any live cell with more than three live neighbours dies, as if by overpopulation.
            grid[i]![j] = CellStatus.Dead;
            changed++;
          }
        } else {
          //  Rule 4: Any dead cell with exactly three live neighbours becomes a live cell, as if by reproduction.
          if (neighbors === 3) {
            grid[i]![j] = CellStatus.Alive;
            changed++;
          }
        }
      }
    }

    // anime({
    //   targets: ".tile-on",
    //   opacity: 0,
    //   margin: "10px",
    //   delay: anime.stagger(50, {
    //     grid: [columns, rows],
    //     from:
    //       columns * rows -
    //       Math.ceil((columns * rows) / 2) -
    //       Math.ceil(columns / 2),
    //   }),
    // });

    setCellStatuses();

    setTimeout(() => {
      gameTick();
    }, 2000);
  };

  const createTile = () => {
    const tile = document.createElement("div");

    tile.classList.add("tile-off");
    tile.style.margin = "1px";
    tile.style.opacity = "0.8";

    return tile;
  };

  const createTiles = (quantity: number) => {
    Array.from(Array(quantity)).map(() => {
      wrapper.appendChild(createTile());
    });
  };

  const setCellStatuses = () => {
    for (var i: number = 0; i < rows; i++) {
      for (var j: number = 0; j < columns; j++) {
        const index = i * columns + j;
        const tile = wrapper.children[index] as HTMLDivElement;

        if (grid[i]![j] === CellStatus.Alive) {
          tile.classList.remove("tile-off");
          tile.classList.add("tile-on");
        } else {
          tile.classList.remove("tile-on");
          tile.classList.add("tile-off");
        }
      }
    }
  };

  // const addDrawingToGrid = (drawing: CellStatus[][]) => {
  //   for (var i: number = 0; i < drawing.length; i++) {
  //     for (var j: number = 0; j < drawing[0]!.length; j++) {
  //       console.log("Drawing at", i, j, drawing[i]![j]!);
  //       grid[i + 20]![j + 20]! = drawing[i]![j]!;
  //     }
  //   }
  // };

  const createGrid = () => {
    wrapper.innerHTML = "";

    columns = getColumns();
    rows = getRows();

    console.log(document.body.clientHeight, document.body.clientWidth);

    wrapper.style.setProperty("--columns", columns.toString());
    wrapper.style.setProperty("--rows", rows.toString());

    createTiles(columns * rows);

    // This is for the random
    // for (var i: number = 0; i < rows; i++) {
    //   for (var j: number = 0; j < columns; j++) {
    //     const random = Math.random();
    //     if (random > 0.9) {
    //       grid[i]![j] = CellStatus.Alive;
    //     } else {
    //       grid[i]![j] = CellStatus.Dead;
    //     }
    //   }
    // }

    grid[20]![21] = CellStatus.Alive;
    grid[21]![22] = CellStatus.Alive;
    grid[22]![20] = CellStatus.Alive;
    grid[22]![21] = CellStatus.Alive;
    grid[22]![22] = CellStatus.Alive;

    for (var i: number = 0; i < rows; i++) {
      for (var j: number = 0; j < columns; j++) {
        if (grid[i]![j] === CellStatus.Alive) {
          console.log("Alive at", i, j);
        }
      }
    }

    setCellStatuses();
  };
  createGrid();

  window.addEventListener("resize", createGrid);

  gameTick();
</script>

<section class="w-full overflow-hidden">
  <div id="wrapper-shadow" class="h-full w-full relative">
    <div id="grid-wrapper" class="h-full w-full grid gap-0 absolute"></div>
  </div>
</section>


---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style is:global>
      p {
        @apply mt-0 mb-8;
      }

      ol,
      ul {
        @apply mb-4 mt-2 list-inside;
      }

      ol {
        @apply list-decimal;
      }

      ul {
        @apply list-disc;
      }

      h1 {
        @apply pb-4 text-justify;
      }
    </style>
  </head>

  <body class="pr-16">
    <Header />

    <main class="flex flex-col justify-center items-center">
      <article class="flex flex-col justify-center items-center container">
        <div class="hero-image relative aspect-[3/1] w-full">
          {
            heroImage && (
              <>
                <Image
                  class="absolute aspect-[3/1] object-cover object-bottom w-full rounded-lg blur-lg"
                  loading="eager"
                  width={1020}
                  height={510}
                  src={heroImage}
                  alt="Hero"
                />
                <Image
                  class="absolute aspect-[3/1] object-cover object-bottom w-full rounded-lg"
                  loading="eager"
                  width={1020}
                  height={510}
                  src={heroImage}
                  alt="Hero"
                />
              </>
            )
          }
        </div>
        <div class="container p-2">
          <div class="title">
            <div class="date text-sm/relaxed">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
